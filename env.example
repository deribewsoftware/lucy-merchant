# Copy to .env.local and set a strong secret (32+ characters).
AUTH_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Optional: create first staff account via POST /api/auth/bootstrap-admin
# Body: { "email", "password", "name", "bootstrapKey", "role"?: "admin" | "system_admin" }
# Use system_admin for full access (team, audit); default is admin.
ADMIN_BOOTSTRAP_KEY=

# Transactional email (verification, password reset, admin invites). Without these, no mail is sent.
# Add these in your hosting dashboard (Vercel → Settings → Environment Variables), then redeploy.
# NODEMAILER_FROM_EMAIL=you@gmail.com
# NODEMAILER_PASSWORD=app-password-16-chars-no-spaces
# Optional: NODEMAILER_USER (defaults to FROM email), NODEMAILER_HOST (default smtp.gmail.com), NODEMAILER_PORT (465 or 587)
# If SMTP DNS fails on your network: NODEMAILER_SMTP_IP=<gmail-smtp-ipv4> and NODEMAILER_TLS_SERVERNAME=smtp.gmail.com
# Links inside emails: NEXT_PUBLIC_APP_URL=https://your-domain.com

# Playwright: base URL when the app is already running (default http://127.0.0.1:3000)
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
